rules_version = '2';

// FoFoDo Storage rules — deployed ONLY to the dedicated fofodo-uploads bucket,
// so they never affect the shared default bucket other apps use.
// Comment attachments live under uploads/{uid}/**. Owner-only direct access;
// rendered in the UI via tokenized download URLs (getDownloadURL).
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 25 * 1024 * 1024 // 25 MB cap
                   // Constrain to media/document types actually used for
                   // attachments — blocks uploading active content (html/svg/js)
                   // that could be abused if the bucket URL is ever opened.
                   && request.resource.contentType.matches('(image|video|audio)/.+|text/plain|application/pdf')
                   && !request.resource.contentType.matches('image/svg.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
