{
  "firestore": {
    "database": "fofodo",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "bucket": "fofoapps-934be-fofodo-uploads",
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "fofodo",
      "runtime": "nodejs22",
      "ignore": ["node_modules", ".git", "*.local", "src", "*.ts", "tsconfig*", ".eslintrc*"],
      "predeploy": ["NODE_OPTIONS=--max-old-space-size=6144 \"$RESOURCE_DIR/node_modules/.bin/tsc\" --project \"$RESOURCE_DIR/tsconfig.json\""]
    }
  ],
  "hosting": {
    "site": "fofodo",
    "public": "app/dist/pwa",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": { "functionId": "fofodoApi", "region": "us-central1" } },
      { "source": "/mcp", "function": { "functionId": "fofodoMcp", "region": "us-central1" } },
      { "source": "/mcp/**", "function": { "functionId": "fofodoMcp", "region": "us-central1" } },
      { "source": "/.well-known/oauth-protected-resource/**", "function": { "functionId": "fofodoOauth", "region": "us-central1" } },
      { "source": "/.well-known/oauth-protected-resource", "function": { "functionId": "fofodoOauth", "region": "us-central1" } },
      { "source": "/.well-known/oauth-authorization-server/**", "function": { "functionId": "fofodoOauth", "region": "us-central1" } },
      { "source": "/.well-known/oauth-authorization-server", "function": { "functionId": "fofodoOauth", "region": "us-central1" } },
      { "source": "/oauth/**", "function": { "functionId": "fofodoOauth", "region": "us-central1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/service-worker.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' data: blob: https:; worker-src 'self' blob:; manifest-src 'self'; connect-src 'self' https://*.googleapis.com wss://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://fofoapps-934be.firebaseapp.com https://*.firebasestorage.app https://firebasestorage.googleapis.com https://apis.google.com; frame-src 'self' https://fofoapps-934be.firebaseapp.com https://*.firebaseapp.com https://accounts.google.com"
          },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "geolocation=(), camera=(), payment=(), usb=(), microphone=(self)" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
        ]
      }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true }
  }
}
