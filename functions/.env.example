# FoFoDo Cloud Functions environment (REQ-OSS-02/03). Copy to .env for local
# dev / set as deploy env vars. All hosted flags default OFF in the OSS build.

# Named Firestore database FoFoDo uses (isolated from the shared default DB).
FOFODO_DB=fofodo

# --- Hosted-tier flags (leave unset/false for self-host) ---
HOSTED=false
ADS_ENABLED=false
FFN_AUTH_ENABLED=false
QUOTAS_ENABLED=false

# --- Quota caps (only enforced when QUOTAS_ENABLED=true) ---
QUOTA_PER_MINUTE=60
QUOTA_PER_DAY=5000

# --- AI (Genkit on Vertex). All AI is behind the per-user kill switch. ---
# OPEN-QUESTIONS D-1: confirm the exact "Gemini 3.1 Flash-Lite" model id.
FOFODO_AI_MODEL=gemini-2.5-flash-lite
FOFODO_AI_LOCATION=us-central1
# Hard global off-switch (overrides every user's aiEnabled): set to 1 to disable.
FOFODO_AI_GLOBAL_OFF=
